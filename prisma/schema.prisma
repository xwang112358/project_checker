generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id                 String    @id @default(cuid())
  name               String
  repoOwner          String
  repoName           String
  description        String?
  visibility         String    @default("private")
  status             String    @default("unknown")
  statusErrorMessage String?
  lastActivityAt     DateTime?
  lastSyncedAt       DateTime?
  latestMilestone    String?
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  commits      Commit[]
  pullRequests PullRequest[]
  issues       Issue[]
  summaries    Summary[]
  manualNotes  ManualNote[]
  milestones   Milestone[]

  @@unique([repoOwner, repoName])
}

model Commit {
  id          String   @id @default(cuid())
  projectId   String
  sha         String
  author      String
  message     String
  date        DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sha])
}

model PullRequest {
  id         String    @id @default(cuid())
  projectId  String
  githubPrId Int
  title      String
  status     String
  openedAt   DateTime
  mergedAt   DateTime?
  closedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, githubPrId])
}

model Issue {
  id            String    @id @default(cuid())
  projectId     String
  githubIssueId Int
  title         String
  status        String
  openedAt      DateTime
  closedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, githubIssueId])
}

model Summary {
  id               String   @id @default(cuid())
  projectId        String
  periodType       String
  periodStart      DateTime
  periodEnd        DateTime
  commitCount      Int      @default(0)
  prOpenedCount    Int      @default(0)
  prMergedCount    Int      @default(0)
  issueOpenedCount Int      @default(0)
  issueClosedCount Int      @default(0)
  generatedSummary String?
  summarySource    String   @default("rule")
  trendLabel       String   @default("none")
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, periodType, periodStart])
}

model ManualNote {
  id                  String   @id @default(cuid())
  projectId           String
  weekStart           DateTime
  outsideProgressNote String?
  nextStepNote        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, weekStart])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  label       String
  description String?
  sourceType  String?
  sourceRef   String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
