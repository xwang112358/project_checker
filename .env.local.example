# Copy this file to .env.local and fill in your values.
# .env.local is never committed to git.

# ── GitHub ────────────────────────────────────────────────────────────────────
# Classic PAT recommended (repo scope) — supports private repos where you are
# a collaborator. Create at: https://github.com/settings/tokens/new
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI provider ───────────────────────────────────────────────────────────────
# Choose one: azure | openai | anthropic | openrouter  (default: azure)
AI_PROVIDER=azure

# ── Azure OpenAI (AI_PROVIDER=azure) ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── OpenAI (AI_PROVIDER=openai) ───────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini          # optional, default: gpt-4o-mini

# ── Anthropic Claude (AI_PROVIDER=anthropic) ──────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022   # optional, default: claude-3-5-haiku-20241022

# ── OpenRouter (AI_PROVIDER=openrouter) ───────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku  # optional, default: anthropic/claude-3.5-haiku

# ── GPU Monitor (SSH) ─────────────────────────────────────────────────────────
# Path to the SSH private key used to connect to lab servers.
# Defaults to ~/.ssh/id_rsa if not set. Authorized keys must be set up on each server.
# SSH_PRIVATE_KEY_PATH=/home/yourname/.ssh/id_rsa
# SSH_PASSPHRASE=                   # leave empty if key has no passphrase
# SSH_CONNECT_TIMEOUT_MS=8000       # per-server connection timeout in ms (default: 8000)
